# ─────────────────────────────────────────────────────────────────
# Vitalize Wellness — Environment Variables Template
# ─────────────────────────────────────────────────────────────────
# 1. Copy this file: cp .env.example .env
# 2. Fill in your real values below
# 3. NEVER commit .env to version control
#
# For Netlify: set these under
#   Site settings → Build & deploy → Environment variables
# ─────────────────────────────────────────────────────────────────

# EmailJS — get these from https://dashboard.emailjs.com
EMAILJS_PUBLIC_KEY=YOUR_PUBLIC_KEY_HERE
EMAILJS_SERVICE_ID=YOUR_SERVICE_ID_HERE
EMAILJS_TEMPLATE_ID=YOUR_TEMPLATE_ID_HERE

# Recipient inbox for patient inquiries (role address preferred)
RECIPIENT_EMAIL=care@vitalizewellness.health
